# Billing (LP-003) — leave unset to disable billing entirely (local stays free/open)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
# Set to "true" to enforce subscription entitlements on API-key auth
BILLING_ENFORCED=
# Public app base URL used for Stripe redirect targets behind reverse proxies
NEXT_PUBLIC_APP_URL=

# Self-serve onboarding (LP-004): public org signup is fail-closed unless true
SELF_SERVE_SIGNUP=false
# Invite link lifetime in hours (default 168, max 720)
ORG_INVITE_TTL_HOURS=168

# Observability (LP-005)
# Sentry-compatible DSN; error tracking is disabled while empty.
SENTRY_DSN=
# Structured api.request logs; set false to silence per-request log lines.
REQUEST_LOGGING=true
