AI_API_KEY=
AI_MAX_RPM=10
AI_MAX_RPD=250
AI_MAX_TPM=250000
AI_RATE_LIMIT_TIER=free
AI_RATE_LIMIT_BACKEND=memory
AI_RATE_LIMIT_SHARED_REQUIRED=false
