{
  "name": "odim",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "pnpm": {
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "browser:smoke": "node scripts/browser-smoke.mjs",
    "lint": "node scripts/lint.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/**/*.test.mjs tests/**/*.test.ts",
    "scrape": "node scrapers/run.ts",
    "scrape:backfill": "node scrapers/run.ts --backfill",
    "scrape:dry-run": "node scrapers/run.ts --dry-run",
    "dream:daily": "node scripts/run-daily-dream.mjs",
    "issue:bootstrap-api-key": "node scripts/issue-bootstrap-api-key.mjs",
    "db:migrate:staging": "node scripts/apply-db-migrations.mjs staging",
    "db:migrate:production": "node scripts/apply-db-migrations.mjs production",
    "db:seed:default-org": "node scripts/seed-default-org.mjs",
    "rls:staging": "node scripts/run-staging-rls-smoke.mjs",
    "release:audit": "node scripts/release-audit.mjs",
    "verify": "node scripts/verify.mjs",
    "setup": "node scripts/setup.mjs",
    "seeds:generate": "node scripts/generate-entity-seeds.mjs",
    "report:weekly": "node scripts/weekly-report.mjs",
    "data:freshness": "node -e \"import('./lib/pipeline/freshness.ts').then(m=>console.log(JSON.stringify(m.DEFAULT_SOURCE_SLA_HOURS,null,2)))\"",
    "backtest": "node scripts/run-backtest.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "2.106.1",
    "lucide-react": "1.16.0",
    "maplibre-gl": "5.24.0",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "zustand": "5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "playwright": "1.60.0",
    "tailwindcss": "4.3.0",
    "typescript": "6.0.3"
  }
}
